# ML device settings (optional — copy to .env or set in the shell)

# Prefer NVIDIA GPU for Marker, embeddings, and Q&A models
TORCH_DEVICE=cuda

# Set to 1 only for development without CUDA (slow Marker conversion)
# ML_ALLOW_CPU=1

# Marker pipeline: fast (default) or quality (full table/equation models, slower)
MARKER_PROFILE=fast

# Marker OCR: disabled by default (faster on digital/text PDFs). Set to 0 for scanned PDFs.
MARKER_DISABLE_OCR=1

# Marker image extraction: disabled by default (text-only markdown). Set to 1 to embed figures.
MARKER_EXTRACT_IMAGES=0
